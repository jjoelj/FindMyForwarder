<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget-picker preview only; the live widget uses widget_map.xml.
  SingleFriendWidget overrides widgetUpdatedLabel to null, so there is no bottom-right
  chip here — the status line carries the timestamp instead.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_rounded_bg"
    android:clipToOutline="true">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/widget_preview_map"
        android:contentDescription="@string/widget_preview_map_desc" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="8dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/widget_chip_bg"
        android:text="@string/widget_preview_single_name" />

    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_margin="6dp"
        android:padding="12dp"
        android:src="@drawable/refresh_24px"
        android:tint="#FFFFFF"
        android:background="@drawable/widget_chip_bg"
        android:contentDescription="@string/widget_preview_refresh_desc" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="8dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/widget_chip_bg"
        android:text="@string/widget_preview_single_status" />

</FrameLayout>
